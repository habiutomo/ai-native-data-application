# Application
APP_NAME=AI-Native Data Application
DEBUG=false

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_native_db

# Redis
REDIS_URL=redis://localhost:6379

# Ollama (external server)
OLLAMA_BASE_URL=http://your-ollama-server:11434
OLLAMA_MODEL=llama3

# Security
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Pipeline
PIPELINE_WORKERS=4
BATCH_SIZE=1000

# Frontend (Render auto-sets this)
VITE_API_URL=
